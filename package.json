{
  "name": "droneftx2-va",
  "version": "1.0.0",
  "description": "Drone FTX training — build VA",
  "main": "electron/main.cjs",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "electron:dev": "powershell -NoProfile -Command \"$env:ELECTRON_START_URL='http://localhost:5173'; electron .\"",
    "start": "npm-run-all -p dev electron:dev",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/rename-electron-output.mjs",
    "build": "npm-run-all build:renderer build:electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.droneftx.va",
    "productName": "Drone FTX VA",
    "copyright": "Copyright Drone FTX",
    "directories": {
      "output": "F:\\DroneFTX2-dist"
    },
    "asar": true,
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-renderer",
        "to": "dist-renderer"
      },
      {
        "from": "VID",
        "to": "dist-renderer/VID"
      },
      {
        "from": "MP3",
        "to": "dist-renderer/MP3"
      },
      {
        "from": "footagecrate-ground-fire-10",
        "to": "dist-renderer/footagecrate-ground-fire-10"
      },
      {
        "from": "FootageCrate-Smoke_Plume_Accent_2",
        "to": "dist-renderer/FootageCrate-Smoke_Plume_Accent_2"
      },
      {
        "from": "scoring-key-VA.json",
        "to": "dist-renderer/scoring-key-VA.json"
      },
      {
        "from": "scoring-tool.html",
        "to": "dist-renderer/scoring-tool.html"
      },
      {
        "from": "zone-editor.html",
        "to": "dist-renderer/zone-editor.html"
      },
      {
        "from": "path-editor.html",
        "to": "dist-renderer/path-editor.html"
      },
      {
        "from": "drone-animation-editor.html",
        "to": "dist-renderer/drone-animation-editor.html"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
